// Life Finance Tracker — schema Prisma
// App MULTI-USER: todas as tabelas de domínio têm userId.
// Núcleo: tudo de dinheiro vira Transaction. Poker e Freelance
// alimentam a Transaction automaticamente. Derivados (ROI, banca,
// patrimônio, a receber) são QUERIES, não colunas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// FINANCEIRO (núcleo)
// ─────────────────────────────────────────────
enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  MANUAL    // digitada à mão
  POKER     // gerada por uma sessão de poker
  FREELANCE // recebimento vinculado a um projeto
}

model Transaction {
  id             String            @id @default(cuid())
  type           TransactionType
  source         TransactionSource @default(MANUAL)
  category       String // ver src/lib/categories.ts
  title          String
  amount         Decimal           @db.Decimal(12, 2)
  date           DateTime
  note           String?

  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  pokerSession   PokerSession?     @relation(fields: [pokerSessionId], references: [id], onDelete: Cascade)
  pokerSessionId String?           @unique
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId      String?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId])
  @@index([date])
  @@index([type, date])
  @@index([category])
  @@index([source])
}

// ─────────────────────────────────────────────
// FREELANCE
// ─────────────────────────────────────────────
model Client {
  id        String    @id @default(cuid())
  name      String
  company   String?
  phone     String?
  email     String?
  note      String?
  projects  Project[]
  
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

enum ProjectStatus {
  IN_PROGRESS
  DONE
  PAUSED
  CANCELLED
}

model Project {
  id            String        @id @default(cuid())
  name          String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId      String
  totalValue    Decimal       @db.Decimal(12, 2)
  receivedValue Decimal       @default(0) @db.Decimal(12, 2)
  status        ProjectStatus @default(IN_PROGRESS)
  startDate     DateTime
  dueDate       DateTime?
  note          String?
  transactions  Transaction[] 
  
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([clientId])
  @@index([status])
}

// ─────────────────────────────────────────────
// POKER
// ─────────────────────────────────────────────
enum PokerType {
  CASH
  TOURNAMENT
  SITNGO
}

model PokerSession {
  id          String       @id @default(cuid())
  type        PokerType
  date        DateTime
  location    String? 

  buyIn       Decimal      @db.Decimal(12, 2)
  cashOut     Decimal      @db.Decimal(12, 2)
  hours       Decimal      @db.Decimal(6, 2)
  netResult   Decimal      @db.Decimal(12, 2)

  note        String?
  transaction Transaction?

  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([date])
  @@index([type, date])
}

// ─────────────────────────────────────────────
// PATRIMÔNIO
// ─────────────────────────────────────────────
model NetWorthSnapshot {
  id              String   @id @default(cuid())
  date            DateTime 
  checkingAccount Decimal  @default(0) @db.Decimal(14, 2)
  investments     Decimal  @default(0) @db.Decimal(14, 2)
  crypto          Decimal  @default(0) @db.Decimal(14, 2)
  otherAssets     Decimal  @default(0) @db.Decimal(14, 2)
  receivables     Decimal  @default(0) @db.Decimal(14, 2)
  pokerBankroll   Decimal  @default(0) @db.Decimal(14, 2)
  total           Decimal  @db.Decimal(14, 2)
  note            String?

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@unique([userId, date]) // 👈 Correção: Permite 1 snapshot por data POR USUÁRIO
  @@index([userId])
  @@index([date])
}

// ─────────────────────────────────────────────
// NEXTAUTH (Autenticação)
// ─────────────────────────────────────────────
model User {
  id            String             @id @default(cuid())
  name          String?
  email         String             @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  transactions  Transaction[]
  clients       Client[]
  projects      Project[]
  pokerSessions PokerSession[]
  netWorths     NetWorthSnapshot[]
  
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}