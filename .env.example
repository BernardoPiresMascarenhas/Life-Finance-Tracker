# ─── Banco de dados (PostgreSQL) ───
# Local via Docker:  postgresql://postgres:postgres@localhost:5432/life_finance?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/life_finance?schema=public"

# ─── Auth.js ───
# Gere com:  npx auth secret    (ou:  openssl rand -base64 32)
AUTH_SECRET="troque-isto-por-um-segredo-aleatorio"

# ─── Usuário único (usado apenas pelo seed) ───
SEED_USER_EMAIL="voce@exemplo.com"
SEED_USER_PASSWORD="uma-senha-forte"
SEED_USER_NAME="Bernardo"
